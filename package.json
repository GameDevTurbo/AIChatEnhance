{
  "name": "task-planner",
  "displayName": "Task Planner",
  "description": "AI 规划窗口 — 并行分析需求，自动匹配 Skill，生成执行计划",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "task-planner-container",
          "title": "Task Planner",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "task-planner-container": [
        {
          "id": "taskPlannerView",
          "name": "Task Planner"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "taskPlannerView",
        "contents": "在编辑器中打开完整规划面板。\n[打开 Task Planner](command:task-planner.openPlanner)"
      }
    ],
    "commands": [
      {
        "command": "task-planner.openPlanner",
        "title": "Task Planner: 打开规划窗口",
        "icon": "$(robot)"
      },
      {
        "command": "task-planner.clearCache",
        "title": "Task Planner: 清除缓存设置"
      }
    ],
    "configuration": {
      "title": "AI Chat Enhance",
      "properties": {
        "aichatEnhance.hiddenModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "要从模型列表中隐藏的模型关键词（匹配 id / name / family，不区分大小写）"
        },
        "aichatEnhance.modelMultipliers": {
          "type": "object",
          "default": {},
          "description": "自定义模型消耗倍率覆盖表，key 为模型 family（小写），value 为倍率数字。示例：{\"my-model\": 2}"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile",
    "test": "node test/test-pure.js && node test/integration.js && node test/integration-extra.js",
    "test:pure": "node test/test-pure.js",
    "test:integration": "node test/integration.js && node test/integration-extra.js",
    "test:sandbox": "start test/sandbox.html"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.0"
  }
}
